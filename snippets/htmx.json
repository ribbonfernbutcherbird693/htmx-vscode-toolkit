{
  "HTMX GET Request": {
    "prefix": "hx-get-basic",
    "body": [
      "<div hx-get=\"${1:/api/endpoint}\" hx-target=\"${2:#result}\" hx-swap=\"${3|innerHTML,outerHTML,beforeend,afterend|}\"${4: hx-trigger=\"${5:click}\"}>${6:Load Content}</div>"
    ],
    "description": "A div with hx-get, hx-target, and hx-swap"
  },
  "HTMX POST Form": {
    "prefix": "hx-post-form",
    "body": [
      "<form hx-post=\"${1:/api/submit}\" hx-target=\"${2:#result}\" hx-swap=\"${3|innerHTML,outerHTML|}\"${4: hx-indicator=\"${5:#spinner}\"}>${6}",
      "  ${7:<input type=\"text\" name=\"${8:field}\" placeholder=\"${9:Enter value}\" />}",
      "  <button type=\"submit\">${10:Submit}</button>",
      "</form>"
    ],
    "description": "A form with hx-post, hx-target, and optional indicator"
  },
  "HTMX Infinite Scroll": {
    "prefix": "hx-infinite-scroll",
    "body": [
      "<div id=\"${1:items}\">",
      "  <!-- Existing items here -->",
      "  <div hx-get=\"${2:/api/items?page=2}\"",
      "       hx-trigger=\"revealed\"",
      "       hx-swap=\"afterend\"",
      "       hx-indicator=\"${3:#loading}\">",
      "    <span id=\"${3:#loading}\" class=\"htmx-indicator\">Loading more...</span>",
      "  </div>",
      "</div>"
    ],
    "description": "Infinite scroll pattern using hx-trigger=\"revealed\""
  },
  "HTMX Live Search": {
    "prefix": "hx-search",
    "body": [
      "<input type=\"search\"",
      "       name=\"${1:q}\"",
      "       hx-get=\"${2:/api/search}\"",
      "       hx-trigger=\"keyup changed delay:${3:300ms}\"",
      "       hx-target=\"${4:#search-results}\"",
      "       hx-indicator=\"${5:.search-indicator}\"",
      "       placeholder=\"${6:Search...}\" />",
      "<div id=\"${4/^#//}\">${7:<!-- Results appear here -->}</div>"
    ],
    "description": "Live search with debounce using hx-trigger delay"
  },
  "HTMX SSE Connection": {
    "prefix": "hx-sse-connect",
    "body": [
      "<div hx-ext=\"sse\" sse-connect=\"${1:/api/events}\">",
      "  <div sse-swap=\"${2:message}\">${3:<!-- SSE content will be swapped here -->}</div>",
      "</div>"
    ],
    "description": "Server-Sent Events connection pattern using the SSE extension"
  },
  "HTMX WebSocket Connection": {
    "prefix": "hx-ws-connect",
    "body": [
      "<div hx-ext=\"ws\" ws-connect=\"${1:/ws/chat}\">",
      "  <div id=\"${2:messages}\">${3:<!-- Messages appear here -->}</div>",
      "  <form ws-send>",
      "    <input type=\"text\" name=\"${4:message}\" placeholder=\"${5:Type a message...}\" />",
      "    <button type=\"submit\">${6:Send}</button>",
      "  </form>",
      "</div>"
    ],
    "description": "WebSocket connection with send form using the WS extension"
  },
  "HTMX Lazy Load": {
    "prefix": "hx-lazy-load",
    "body": [
      "<div hx-get=\"${1:/api/content}\"",
      "     hx-trigger=\"load\"",
      "     hx-swap=\"${2|innerHTML,outerHTML|}\"",
      "     hx-indicator=\"${3:#loading}\">",
      "  <span id=\"${3/^#//}\" class=\"htmx-indicator\">${4:Loading...}</span>",
      "</div>"
    ],
    "description": "Lazy loading pattern that fetches content on page load"
  },
  "HTMX Delete with Confirmation": {
    "prefix": "hx-confirm-delete",
    "body": [
      "<button hx-delete=\"${1:/api/items/${2:id}}\"",
      "        hx-confirm=\"${3:Are you sure you want to delete this?}\"",
      "        hx-target=\"${4|closest tr,closest .item,this|}\"",
      "        hx-swap=\"${5|outerHTML,delete|}\">${6:Delete}</button>"
    ],
    "description": "Delete button with confirmation dialog"
  },
  "HTMX Polling": {
    "prefix": "hx-polling",
    "body": [
      "<div hx-get=\"${1:/api/status}\"",
      "     hx-trigger=\"every ${2:2s}\"",
      "     hx-swap=\"innerHTML\">${3:<!-- Polling content -->}</div>"
    ],
    "description": "Polling pattern that fetches data at regular intervals"
  },
  "HTMX Click to Edit": {
    "prefix": "hx-click-to-edit",
    "body": [
      "<div id=\"${1:editable}\" hx-get=\"${2:/api/edit-form}\" hx-trigger=\"click\" hx-swap=\"outerHTML\">",
      "  ${3:Click to edit this content}",
      "</div>"
    ],
    "description": "Click-to-edit inline editing pattern"
  },
  "HTMX Boosted Navigation": {
    "prefix": "hx-boost-nav",
    "body": [
      "<nav hx-boost=\"true\" hx-target=\"${1:#content}\" hx-swap=\"innerHTML\" hx-push-url=\"true\">",
      "  <a href=\"${2:/page1}\">${3:Page 1}</a>",
      "  <a href=\"${4:/page2}\">${5:Page 2}</a>",
      "</nav>",
      "<main id=\"${1/^#//}\">",
      "  ${6:<!-- Page content -->}",
      "</main>"
    ],
    "description": "Boosted navigation with SPA-like URL updates"
  },
  "HTMX Modal Trigger": {
    "prefix": "hx-modal",
    "body": [
      "<button hx-get=\"${1:/api/modal-content}\"",
      "        hx-target=\"${2:#modal-container}\"",
      "        hx-swap=\"innerHTML\"",
      "        hx-trigger=\"click\">${3:Open Modal}</button>",
      "<div id=\"${2/^#//}\">${4:<!-- Modal content loads here -->}</div>"
    ],
    "description": "Button that loads modal content via HTMX"
  },
  "HTMX File Upload": {
    "prefix": "hx-file-upload",
    "body": [
      "<form hx-post=\"${1:/upload}\" hx-encoding=\"multipart/form-data\" hx-target=\"${2:#result}\" hx-indicator=\"${3:#progress}\">",
      "\t<input type=\"file\" name=\"${4:file}\" />",
      "\t<button type=\"submit\">Upload</button>",
      "\t<div id=\"progress\" class=\"htmx-indicator\">Uploading...</div>",
      "</form>"
    ],
    "description": "File upload form with multipart encoding and progress indicator"
  },
  "HTMX Dependent Dropdown": {
    "prefix": "hx-dependent-dropdown",
    "body": [
      "<select name=\"${1:category}\" hx-get=\"${2:/options}\" hx-target=\"${3:#sub-select}\" hx-trigger=\"change\">",
      "\t<option value=\"\">Select ${1:category}</option>",
      "</select>",
      "<select id=\"sub-select\" name=\"${4:subcategory}\">",
      "\t<option value=\"\">Select ${4:subcategory}</option>",
      "</select>"
    ],
    "description": "Cascading/dependent dropdown that loads options on change"
  },
  "HTMX OOB Swap": {
    "prefix": "hx-oob-swap",
    "body": [
      "<div id=\"${1:target-id}\" hx-swap-oob=\"${2|true,innerHTML,outerHTML,beforebegin,afterbegin,beforeend,afterend|}\">",
      "\t${3:Updated content}",
      "</div>"
    ],
    "description": "Out-of-band swap element for updating multiple targets"
  },
  "HTMX Table Row Edit": {
    "prefix": "hx-table-row",
    "body": [
      "<tr id=\"${1:row-1}\">",
      "\t<td>${2:Name}</td>",
      "\t<td>${3:Value}</td>",
      "\t<td>",
      "\t\t<button hx-get=\"${4:/edit/1}\" hx-target=\"#${1:row-1}\" hx-swap=\"outerHTML\">Edit</button>",
      "\t\t<button hx-delete=\"${5:/items/1}\" hx-target=\"#${1:row-1}\" hx-swap=\"outerHTML\" hx-confirm=\"Delete this row?\">Delete</button>",
      "\t</td>",
      "</tr>"
    ],
    "description": "Table row with inline edit and delete buttons"
  },
  "HTMX Progress Bar": {
    "prefix": "hx-progress",
    "body": [
      "<div hx-get=\"${1:/progress}\" hx-trigger=\"every ${2:1s}\" hx-target=\"this\" hx-swap=\"innerHTML\">",
      "\t<div class=\"progress-bar\" style=\"width: ${3:0}%\">${3:0}%</div>",
      "</div>"
    ],
    "description": "Auto-updating progress bar with polling"
  },
  "HTMX Tabs": {
    "prefix": "hx-tabs",
    "body": [
      "<div class=\"tabs\" hx-target=\"#${1:tab-content}\" hx-swap=\"innerHTML\">",
      "\t<button hx-get=\"${2:/tab1}\" class=\"active\">Tab 1</button>",
      "\t<button hx-get=\"${3:/tab2}\">Tab 2</button>",
      "\t<button hx-get=\"${4:/tab3}\">Tab 3</button>",
      "</div>",
      "<div id=\"${1:tab-content}\">",
      "\t${5:Tab content here}",
      "</div>"
    ],
    "description": "Tab navigation loading content via HTMX"
  },
  "HTMX Toast Notification": {
    "prefix": "hx-toast",
    "body": [
      "<div id=\"${1:toast-container}\" hx-swap-oob=\"afterbegin\">",
      "\t<div class=\"toast\" role=\"alert\">",
      "\t\t${2:Notification message}",
      "\t</div>",
      "</div>"
    ],
    "description": "Toast notification via OOB swap"
  },
  "HTMX Form Validation": {
    "prefix": "hx-form-validation",
    "body": [
      "<form hx-post=\"${1:/submit}\" hx-target=\"${2:#result}\" hx-swap=\"${3:innerHTML}\">",
      "\t<input name=\"${4:email}\" type=\"${5:email}\" hx-get=\"${6:/validate}\" hx-trigger=\"change\" hx-target=\"next .error\" />",
      "\t<span class=\"error\"></span>",
      "\t<button type=\"submit\">Submit</button>",
      "</form>"
    ],
    "description": "Form with inline field validation on change"
  },
  "HTMX Page Template": {
    "prefix": "hx-template",
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"en\">",
      "<head>",
      "\t<meta charset=\"UTF-8\">",
      "\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
      "\t<title>${1:HTMX App}</title>",
      "\t<script src=\"https://unpkg.com/htmx.org@${2:2.0.4}\"></script>",
      "</head>",
      "<body>",
      "\t${3}",
      "</body>",
      "</html>"
    ],
    "description": "Full HTML page with HTMX script included"
  },
  "HTMX Active Search": {
    "prefix": "hx-active-search",
    "body": [
      "<input type=\"search\" name=\"${1:q}\"",
      "\thx-get=\"${2:/search}\"",
      "\thx-trigger=\"input changed delay:${3:300ms}, search\"",
      "\thx-target=\"${4:#results}\"",
      "\thx-indicator=\"${5:.spinner}\"",
      "\tplaceholder=\"${6:Search...}\" />",
      "<span class=\"spinner htmx-indicator\">Searching...</span>",
      "<div id=\"results\"></div>"
    ],
    "description": "Active search input with debounce and loading indicator"
  },
  "HTMX Bulk Actions": {
    "prefix": "hx-bulk-actions",
    "body": [
      "<form hx-post=\"${1:/bulk}\" hx-target=\"${2:#list}\" hx-swap=\"${3:innerHTML}\">",
      "\t<button type=\"submit\" name=\"action\" value=\"${4:delete}\">Delete Selected</button>",
      "\t<div id=\"list\">",
      "\t\t<label><input type=\"checkbox\" name=\"ids\" value=\"${5:1}\"> Item 1</label>",
      "\t\t<label><input type=\"checkbox\" name=\"ids\" value=\"${6:2}\"> Item 2</label>",
      "\t</div>",
      "</form>"
    ],
    "description": "Bulk action form with checkboxes"
  }
}
